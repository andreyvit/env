#!/usr/bin/env perl
use strict;
use warnings;

@ARGV == 1 && $ARGV[0] =~ /^(\d{1,2}):(\d{2})$/
    or die "Usage: $0 HH:MM\n";

my ($h, $m) = ($1, $2);

my ($sec, $min, $hour) = localtime;
my $now    = $hour*3600 + $min*60 + $sec;
my $target = $h*3600    + $m*60;
my $sleep  = ($target - $now) % 86_400;   # wrap to next day if negative

printf "Sleeping %02d:%02d:%02d until %s …\n",
        $sleep/3600, ($sleep/60)%60, $sleep%60,
        scalar localtime(time + $sleep);

sleep $sleep;
